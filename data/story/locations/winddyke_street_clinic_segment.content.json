        "actionTextByActionId": {
          "to_corner_notice_day": {
            "actionLabel": {
              "base": "沿反光杆去转角公告段",
              "visibilityVariants": [
                { "when": { "visibilityBand": "low" }, "mode": "replace", "text": "贴着反光杆去转角公告段" },
                { "when": { "visibilityBand": "hazard" }, "mode": "replace", "text": "紧贴反光杆去转角公告段" }
              ]
            },
            "logLinesByIndex": {
              "0": {
                "base": "你沿着反光杆往前走，压实雪面和编号序列把线路维持得很稳。",
                "lightVariants": [
                  { "when": { "lightPhase": ["twilight", "polar_night"] }, "mode": "replace", "text": "你沿着反光杆往前贴过去，近处编号比远端轮廓更可靠。" }
                ],
                "visibilityVariants": [
                  { "when": { "visibilityBand": "low" }, "mode": "replace", "text": "雪雾把远端边线揉散后，你只能贴着最近几根反光杆把方向续上。" },
                  { "when": { "visibilityBand": "hazard" }, "mode": "replace", "text": "能见度被压低后，你几乎是靠最近的反光边一点点把路线续到转角。" }
                ]
              }
            }
          },
          "to_corner_notice_night": {
            "actionLabel": {
              "base": "沿反光杆去转角公告段",
              "lightVariants": [
