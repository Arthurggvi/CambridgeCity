              ],
              "visibilityVariants": [
                { "when": { "visibilityBand": "low" }, "mode": "replace", "text": "贴着反光杆去转角公告段" },
                { "when": { "visibilityBand": "hazard" }, "mode": "replace", "text": "紧贴反光杆去转角公告段" }
