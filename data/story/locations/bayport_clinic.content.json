  "RuntimeText": {
    "mapTextByMapId": {
      "bayport_clinic": {
        "sceneId": "1.0",
        "description": {
          "base": "你站在前厅中央。长椅贴墙排开，接待台后文件堆叠，窗口在缓慢运转。",
          "serviceVariants": [
            {
              "when": { "serviceBand": "day_service" },
              "text": "白班窗口仍在受理，队伍不算长，但推进得很慢。"
            },
            {
              "when": { "serviceBand": "night_service" },
              "text": "当前只留必要受理，前厅人更少，窗口更多是在维持夜班流程。"
            }
          ],
          "lightVariants": [
            {
              "when": { "lightPhase": "polar_day" },
              "text": "窗外的亮度被长时间摊平，玻璃上没有真正的暗面，只有一层冷白反光。"
            },
            {
              "when": { "lightPhase": "low_sun" },
              "text": "低角日照压在玻璃外侧，亮度能照进来，但始终偏冷。"
            },
            {
              "when": { "lightPhase": ["twilight", "polar_night"] },
              "text": "窗外更多只剩冷光反雪，室内照明把前厅往里收紧。"
            }
          ],
          "weatherVariants": [
            {
              "when": { "isSnowing": true },
              "text": "消毒水味里仍混着一点被门缝带进来的潮湿雪气。"
            }
          ],
          "visibilityVariants": [
            {
              "when": { "visibilityBand": "low" },
              "text": "玻璃外的路面边线被雪雾压淡，外部轮廓开始往一层灰白里缩。"
            },
            {
              "when": { "visibilityBand": "hazard" },
              "text": "窗外几乎只剩贴近建筑的最近轮廓，远一点的分流杆和脚印都被吃掉了。"
            }
          ]
        }
      },
      "bayport_clinic_counter_night": {
        "sceneId": "1.2",
        "description": {
          "base": "你走到窗口前。护士抬头看了你一眼。",
          "serviceVariants": [
            {
              "when": { "serviceBand": "night_service" },
              "text": "当前是夜班受理窗口，制度上只收急诊，其余一律等白班。"
            },
            {
              "when": { "serviceBand": "day_service" },
              "text": "这处窗口在制度上应由白班接手，夜班限制语气会在交班后撤掉。"
            }
          ]
        }
      },
      "bayport_clinic_upstairs_hall": {
        "sceneId": "2.1",
        "description": {
          "base": "灯光更冷，走廊两侧是诊室门与门牌编号，候诊区铁长椅贴墙排开。",
          "serviceVariants": [
            {
              "when": { "serviceBand": "day_service" },
              "text": "白班时二楼的门牌和分诊流转更活，诊室门后的出入与纸张声都更密。"
            },
            {
              "when": { "serviceBand": "night_service" },
              "text": "夜班时这里只保留必要通行和必要问答，大部分诊室门都维持关闭。"
            }
          ],
          "lightVariants": [
            {
              "when": { "lightPhase": "polar_day" },
              "text": "尽头窗面的反光更平，连门牌边缘都被照得发白。"
            },
            {
              "when": { "lightPhase": "low_sun" },
              "text": "窗外冷光斜斜打进来，走廊亮一段、冷一段。"
            },
            {
              "when": { "lightPhase": ["twilight", "polar_night"] },
              "text": "自然光退下去后，走廊主要靠人工照明撑住层次，门牌反光更硬。"
            }
          ],
          "weatherVariants": [
            {
              "when": { "isSnowing": true },
              "text": "空气里仍有一点从楼梯口带上来的湿冷气。"
            }
          ],
          "visibilityVariants": [
            {
              "when": { "visibilityBand": "low" },
              "text": "尽头窗外的外部轮廓被雪雾揉散，只剩近处屋檐和玻璃上的水痕先显出来。"
            },
            {
              "when": { "visibilityBand": "hazard" },
              "text": "窗外几乎只剩一片被风雪压平的亮白，外部方向感完全交给室内标识。"
            }
          ]
        }
      },
      "bayport_clinic_rooftop": {
        "sceneId": "2.4",
        "description": {
          "base": "诊所天台。护墙被雪粒打得发白，风把远处灯带压成断续的线。",
          "lightVariants": [
            {
              "when": { "lightPhase": ["twilight", "polar_night"] },
              "text": "光线更低时，远处只剩模糊轮廓，方向主要靠灯和风声判断。"
            }
          ],
          "visibilityVariants": [
            {
              "when": { "visibilityBand": "hazard" },
              "text": "能见度压到最低时，护墙外侧几乎只剩一层被风雪抹开的亮白。"
            }
          ]
        }
      },
      "bayport_clinic_obs": {
        "sceneId": "2.3",
        "description": {
          "base": "观察位床位更密、帘子更紧，流程以短促指令和记录为主。",
          "serviceVariants": [
            {
              "when": { "serviceBand": "day_service" },
              "text": "白班接手后，记录、交接和问询都会更密，流程声也更连续。"
            },
            {
              "when": { "serviceBand": "night_service" },
              "text": "夜班只维持必要观察，护士脚步和说话都压得更短。"
            }
          ],
          "lightVariants": [
            {
              "when": { "lightPhase": "polar_day" },
              "text": "帘子边缘能接到一点持续的冷白亮度，但这里仍以床头灯和走廊灯为主。"
            },
            {
              "when": { "lightPhase": ["twilight", "polar_night"] },
              "text": "自然光退下去后，观察位几乎完全缩进帘子、床头灯和走廊灯构成的局部亮区里。"
            }
          ],
          "weatherVariants": [
            {
              "when": { "isSnowing": true },
              "text": "偶尔开合的门会把一点更冷的空气带进来。"
            }
          ],
          "visibilityVariants": [
            {
              "when": { "visibilityBand": "hazard" },
              "text": "外部视野被压缩后，病区边缘的窗面也只剩一层模糊亮白，不再提供任何外界参照。"
            }
          ]
        }
      },
      "bayport_clinic_ward": {
        "sceneId": "2.2",
        "description": {
          "base": "病房区贴着床位号与注意事项，护士站在转角，空气干冷，消毒水味更重。",
          "serviceVariants": [
            {
              "when": { "serviceBand": "day_service" },
              "text": "白班时查房、问询和出院办理会把护士站周围的流程拉得更满。"
            },
            {
              "when": { "serviceBand": "night_service" },
              "text": "夜班时这里只保留必要照护和值守，动作更慢，说话更短。"
            }
          ],
          "lightVariants": [
            {
              "when": { "lightPhase": "polar_day" },
              "text": "窗边帘布会被外面的长亮度透出一层发白的边。"
            },
            {
              "when": { "lightPhase": "low_sun" },
              "text": "窗外冷光偶尔能蹭到床位边缘，但病房主体仍由床头灯和走廊灯维持。"
            },
            {
              "when": { "lightPhase": ["twilight", "polar_night"] },
              "text": "自然光几乎退净后，病房区会更明显地缩回床头灯和护士站附近的照明里。"
            }
          ],
          "weatherVariants": [
            {
              "when": { "isSnowing": true },
              "text": "偶尔仍能感觉到外部风雪把整栋楼的冷意往里推了一层。"
            }
          ],
          "visibilityVariants": [
            {
              "when": { "visibilityBand": "low" },
              "text": "窗外能见度一下滑，玻璃外的建筑边线就只剩断续轮廓。"
            },
            {
              "when": { "visibilityBand": "hazard" },
              "text": "风雪把窗外视野压成一片空白后，病房里的一切参照都回到床位号、帘布和护士站灯上。"
            }
          ]
        }
      }
    },
