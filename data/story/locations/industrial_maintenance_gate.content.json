  ],
  "InteractionList": [
    { "id": "maintenance_scan_tools", "scene": "1.0", "type": "IDLE_OBSERVE", "time_cost": "0:01", "condition": null, "goto": "1.0", "text": "看看门口的工具箱和零件箱" },
    { "id": "maintenance_check_access", "scene": "1.0", "type": "IDLE_OBSERVE", "time_cost": "0:01", "condition": null, "goto": "1.0", "text": "检查维修区门禁" },
    { "id": "maintenance_watch_staff_flow", "scene": "1.0", "type": "IDLE_OBSERVE", "time_cost": "0:01", "condition": null, "goto": "1.0", "text": "观察进出的人员" },
    { "id": "maintenance_listen_inside", "scene": "1.0", "type": "IDLE_OBSERVE", "time_cost": "0:01", "condition": null, "goto": "1.0", "text": "凑近听听里头的动静" },
    { "id": "maintenance_ask_entry_help", "scene": "1.0", "type": "IDLE_OBSERVE", "time_cost": "0:01", "condition": null, "goto": "1.0", "text": "试着问问能不能进去帮忙" },
